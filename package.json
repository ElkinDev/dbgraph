{
  "name": "@niklerk23/dbgraph",
  "version": "0.0.0",
  "description": "Database schema graph for AI agents — index your database catalog into a local graph, served over MCP",
  "type": "module",
  "license": "MIT",
  "private": true,
  "engines": {
    "node": ">=22"
  },
  "files": [
    "dist"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "bin": {
    "dbgraph": "./dist/cli.js",
    "dbgraph-mcp": "./dist/mcp.js"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:watch": "vitest",
    "lint": "eslint .",
    "format": "prettier --write ."
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ElkinDev/dbgraph.git"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "better-sqlite3": "12.11.1"
  },
  "optionalDependencies": {
    "mongodb": "^7.3.0",
    "mssql": "12.5.5",
    "mysql2": "^3.22.5",
    "pg": "^8.21.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/better-sqlite3": "7.6.13",
    "@types/node": "^25.9.3",
    "eslint": "^10.5.0",
    "prettier": "^3.9.4",
    "testcontainers": "12.0.3",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1",
    "vitest": "^4.1.9"
  }
}
